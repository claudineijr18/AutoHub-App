<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:padding="20dp">

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nova Modificação"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Nome -->
    <EditText
        android:id="@+id/etNomeMod"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/campo_padrao"
        android:hint="Nome da modificação"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:inputType="text"
        android:backgroundTint="@null"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Status -->
    <Spinner
        android:id="@+id/spStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/campo_padrao"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/etNomeMod"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Custo -->
    <EditText
        android:id="@+id/etCusto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/campo_padrao"
        android:hint="Custo"
        android:textColor="#FFFFFF"
        android:textColorHint="#AAAAAA"
        android:inputType="numberDecimal"
        android:backgroundTint="@null"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/spStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botão -->
    <Button
        android:id="@+id/btnSalvar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Salvar"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/etCusto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>